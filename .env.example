# Copy to .env and fill in. The dotenv loader picks this up.

# ── Backend (default for Claude models) ──────────────────────────────
# "anthropic" (direct API, default), "vertex" (Vertex AI), or "gemini".
# Gemini models are auto-detected by name — you only need this for Claude.
VULN_AGENT_BACKEND=anthropic

# Required for backend=anthropic:
ANTHROPIC_API_KEY=

# Required for backend=gemini (or Gemini model strings):
# GOOGLE_API_KEY=

# Required for backend=vertex:
# GOOGLE_CLOUD_PROJECT=your-project
# GOOGLE_CLOUD_LOCATION=us-east5

# ── Per-role model selection ─────────────────────────────────────────
# Each role can use a different model (even from different providers).
# Model strings starting with "gemini-" auto-route to Google AI.
#
# Examples:
#   All Claude:   root=claude-opus-4-6, scanner=claude-sonnet-4-6
#   All Gemini:   root=gemini-2.5-pro, scanner=gemini-2.5-flash
#   Mixed:        root=gemini-2.5-pro, scanner=claude-sonnet-4-6
#
# VULN_AGENT_ROOT_MODEL=claude-opus-4-6
# VULN_AGENT_SCANNER_MODEL=claude-sonnet-4-6
# VULN_AGENT_ANALYZER_MODEL=claude-sonnet-4-6

# Legacy model overrides (still work, but per-role vars above take precedence):
# VULN_AGENT_OPUS_MODEL=claude-opus-4-6
# VULN_AGENT_SONNET_MODEL=claude-sonnet-4-6
# VULN_AGENT_GEMINI_PRO_MODEL=gemini-2.5-pro
# VULN_AGENT_GEMINI_FLASH_MODEL=gemini-2.5-flash

# ── Pipeline settings ────────────────────────────────────────────────
# VULN_AGENT_MAX_SCANNERS=6

# Sandbox: "local" (subprocess with import guards) or "docker" (container).
# VULN_AGENT_SANDBOX=docker

# Security gateway limits:
# VULN_AGENT_MAX_TOOL_CALLS=2500
# VULN_AGENT_MAX_OUTPUT_BYTES=102400

# Target codebase (defaults to bundled vulnerable_flask_app):
# TARGET_CODEBASE_ROOT=targets/pygoat
