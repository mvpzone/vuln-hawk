# Copy to .env and fill in. The dotenv loader picks this up.

# Backend: "anthropic" (direct API, default) or "vertex" (Vertex AI).
VULN_AGENT_BACKEND=anthropic

# Required for backend=anthropic:
ANTHROPIC_API_KEY=

# Required for backend=vertex:
# GOOGLE_CLOUD_PROJECT=your-project
# GOOGLE_CLOUD_LOCATION=us-east5

# Optional: override model per role. Defaults shown.
# VULN_AGENT_SONNET_MODEL=claude-sonnet-4-6
# VULN_AGENT_HAIKU_MODEL=claude-haiku-4-5-20251001
# VULN_AGENT_OPUS_MODEL=claude-opus-4-6

# Optional: max parallel scanners in the pipeline. Default 6.
# VULN_AGENT_MAX_SCANNERS=6

# Sandbox: "local" (subprocess with import guards, default) or
# "docker" (runs snippets in an isolated container — needs Docker).
# VULN_AGENT_SANDBOX=docker

# Security gateway: tool call limits and output caps.
# VULN_AGENT_MAX_TOOL_CALLS=2500
# VULN_AGENT_MAX_OUTPUT_BYTES=102400

# Optional: override the target codebase. Defaults to the bundled
# vulnerable_flask_app under targets/.
# TARGET_CODEBASE_ROOT=
